############################################
# APP
############################################
APP_NAME=namastex
APP_ENV=local
APP_URL=http://localhost:8890

LOG_LEVEL=debug

############################################
# BRAIN
############################################
BRAIN_HOST=0.0.0.0
BRAIN_PORT=8890
BRAIN_API_KEY=brain-dev-key

############################################
# OMNI
############################################
OMNI_API_KEY=
OMNI_BASE_URL=http://localhost:8882
OMNI_WEBHOOK_SECRET=

############################################
# DATABASE (futuro)
############################################
DB_CLIENT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=namastex
DB_USERNAME=postgres
DB_PASSWORD=postgres

############################################
# CACHE / MEMORY
############################################
CACHE_DRIVER=memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

############################################
# MESSAGE BROKER (OMNI / EVENT BUS)
############################################
NATS_ENABLED=true
NATS_SERVERS=nats://localhost:4222
NATS_CLIENT_NAME=namastex

############################################
# LLM PROVIDERS
############################################

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Fallback — Brain tenta Anthropic primeiro, depois OpenAI
LLM_DEFAULT_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=openai

############################################
# BRAIN — MODELS
############################################
BRAIN_DEFAULT_MODEL=claude-sonnet-4-20250514
BRAIN_ROUTER_MODEL=claude-haiku-4-5-20251001
BRAIN_REVIEW_MODEL=claude-haiku-4-5-20251001

############################################
# BRAIN — MEMORY / SESSÃO
############################################
BRAIN_MAX_HISTORY=20
BRAIN_SESSION_TTL_MS=3600000
BRAIN_SUMMARIZE_AFTER=20

############################################
# BRAIN — TIMEOUTS
############################################
BRAIN_LLM_TIMEOUT_MS=30000
BRAIN_PROCESS_TIMEOUT_MS=45000

############################################
# BRAIN — REVIEW
############################################
BRAIN_REVIEW_ENABLED=true

############################################
# AGENTS
############################################
AGENT_ROUTER_ENABLED=true
AGENT_SUPPORT_ENABLED=true
AGENT_SALES_ENABLED=true
AGENT_OPS_ENABLED=true
AGENT_REVIEW_ENABLED=true

############################################
# OMNI CHANNELS
############################################

# WhatsApp — escolha provider: "twilio" ou "meta-cloud"
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=twilio

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_SECRET=

# Meta WhatsApp Cloud API
META_WHATSAPP_ENABLED=false
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_API_VERSION=v21.0

# WhatsApp Geral
WEBHOOK_BASE_URL=
DEFAULT_TENANT_ID=default
DEFAULT_INSTANCE_ID=default
WHATSAPP_SEND_TIMEOUT_MS=10000
WHATSAPP_MAX_RETRIES=2

# Discord
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

############################################
# WEBHOOKS
############################################
WEBHOOK_SECRET=supersecretkey

############################################
# AUTH / SECURITY
############################################
JWT_SECRET=changeme
JWT_EXPIRES_IN=1d

############################################
# OBSERVABILITY
############################################
ENABLE_TRACING=true
TRACE_PROVIDER=console

############################################
# FILE STORAGE
############################################
STORAGE_DRIVER=local

############################################
# RATE LIMIT
############################################
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

############################################
# FEATURE FLAGS
############################################
FEATURE_MEMORY_ENABLED=true
FEATURE_AGENT_REVIEW=true
FEATURE_EVENT_RETRY=true

############################################
# DEV
############################################
DEBUG=true
