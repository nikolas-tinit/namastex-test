############################################
# APP
############################################
APP_NAME=namastex
APP_ENV=local
APP_PORT=3000
APP_URL=http://localhost:3000

LOG_LEVEL=debug

############################################
# API
############################################
API_PREFIX=/api/v1

############################################
# DATABASE
############################################
DB_CLIENT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=namastex
DB_USERNAME=postgres
DB_PASSWORD=postgres

############################################
# CACHE / MEMORY
############################################
CACHE_DRIVER=memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

############################################
# MESSAGE BROKER (OMNI / EVENT BUS)
############################################
NATS_ENABLED=true
NATS_SERVERS=nats://localhost:4222
NATS_CLIENT_NAME=namastex

############################################
# LLM PROVIDERS
############################################

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Fallback
LLM_DEFAULT_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic

############################################
# AGENTS
############################################
AGENT_ROUTER_ENABLED=true
AGENT_SUPPORT_ENABLED=true
AGENT_SALES_ENABLED=true
AGENT_OPS_ENABLED=true
AGENT_REVIEW_ENABLED=true

############################################
# OMNI CHANNELS
############################################

# WhatsApp (ex: Twilio ou Cloud API)
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_KEY=
WHATSAPP_WEBHOOK_SECRET=

# Discord
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

############################################
# WEBHOOKS
############################################
WEBHOOK_SECRET=supersecretkey

############################################
# AUTH / SECURITY
############################################
JWT_SECRET=changeme
JWT_EXPIRES_IN=1d

############################################
# OBSERVABILITY
############################################
ENABLE_TRACING=true
TRACE_PROVIDER=console

############################################
# FILE STORAGE
############################################
STORAGE_DRIVER=local

############################################
# RATE LIMIT
############################################
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

############################################
# FEATURE FLAGS
############################################
FEATURE_MEMORY_ENABLED=true
FEATURE_AGENT_REVIEW=true
FEATURE_EVENT_RETRY=true

############################################
# DEV
############################################
DEBUG=true
